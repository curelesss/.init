{ pkgs, ... }:

{
  i18n.inputMethod = {
    enable = true;
    type = "fcitx5";
    fcitx5.waylandFrontend = true;
    fcitx5.ignoreUserConfig = true; 

    fcitx5.addons = with pkgs; [
      fcitx5-rime
      qt6Packages.fcitx5-chinese-addons
      fcitx5-gtk
      rime-data
      rime-ice
    ];

    fcitx5.settings = {
      inputMethod = {
        "Groups/0" = {
          Name = "Default";
          "Default Layout" = "us";
          DefaultIM = "rime";
        };
        "Groups/0/Items/0" = { Name = "keyboard-us"; };
        "Groups/0/Items/1" = { Name = "rime"; };
      };
    };
  };

  systemd.user.services.fcitx5 = {
    description = "Fcitx5 input method";
    wantedBy = [ "graphical-session.target" ];
    partOf = [ "graphical-session.target" ];
    serviceConfig = {
      # CRITICAL FIX: Use the system-wide wrapped binary, NOT the raw package!
      ExecStart = "/run/current-system/sw/bin/fcitx5 -D";
      Restart = "always";
    };
  };
}
